{
  "expo": {
    "name": "Terroir",
    "slug": "terroir",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/android/play_store_512.png",
    "scheme": "terroir",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/ios/icon.png",
      "supportsTablet": true,
      "bundleIdentifier": "com.terroir.eribert",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android/ic_launcher_foreground.png",
        "backgroundImage": "./assets/images/android/ic_launcher_background.png",
        "backgroundColor": "#eeebe4",
        "monochromeImage": "./assets/images/android/ic_launcher_monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.terroir.somosnodo"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/web/favicon.ico"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#eeebe4",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 200
          },
          "ios": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 200
          }
        }
      ],
      "expo-image",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "44db9555-c202-4fa0-a582-03b00dd0dfee"
      }
    },
    "owner": "somosnododev"
  }
}
