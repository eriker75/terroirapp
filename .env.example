# =============================================================
# TERROIR MOBILE (Expo) — Plantilla de variables de entorno
# Copia a `.env` y rellena. Las EXPO_PUBLIC_* se inyectan en el bundle.
# Para builds en EAS, define también estas vars en eas.json (env) o en
# EAS → Environment variables (ver docs/integrations/google-login.md).
# =============================================================

# Backend. En dev se autodetecta el host de Metro si se omite (ver baseUrl.ts);
# en release usa https://terroirapp.com. Override total con esta var.
EXPO_PUBLIC_BACKEND_URL=

# (Opcional) Puerto del backend en dev cuando se usa la IP de Metro.
# EXPO_PUBLIC_DEV_BACKEND_PORT=3000

# --- Login con Google (@react-native-google-signin) ---
# WEB_CLIENT_ID: IMPRESCINDIBLE. Es el client ID OAuth de tipo "Web application".
#   El id_token que emite el SDK lleva ESTE valor como `aud` (lo verifica el backend),
#   en iOS y en Android.
# IOS_CLIENT_ID: client ID OAuth de tipo iOS. Su valor INVERTIDO va como
#   `iosUrlScheme` en app.json (com.googleusercontent.apps.XXXX).
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=

# --- Login con Apple (expo-apple-authentication) ---
# No requiere variables: usa el bundle id de la app (com.terroir.eribert) y la
# entitlement `usesAppleSignIn` de app.json. Sólo iOS 13+. Ver docs.
