# Override completo de la URL del backend.
# Si lo dejas comentado: en dev autodetecta http://<IP-de-Metro>:<EXPO_PUBLIC_DEV_BACKEND_PORT|3000>
#                       en release usa https://terroirapp.com
# Descoméntalo solo para apuntar a staging o un host fijo.
# EXPO_PUBLIC_BACKEND_URL=https://staging.terroirapp.com
EXPO_PUBLIC_BACKEND_URL=http://localhost:3000

# Solo afecta a dev (cuando se autodetecta el host). Default: 3000.
# EXPO_PUBLIC_DEV_BACKEND_PORT=3000
