# Override completo de la URL del backend.
# Si lo dejas comentado: en dev autodetecta http://<IP-de-Metro>:<EXPO_PUBLIC_DEV_BACKEND_PORT|3000>
#                       en release usa https://terroirapp.com
# Descoméntalo solo para apuntar a staging o un host fijo.
# EXPO_PUBLIC_BACKEND_URL=https://staging.terroirapp.com
# Dispositivo físico por USB: dejamos la autodetección (host=localhost) + adb reverse
# tcp:3000, que va por USB y no depende de la WiFi. El script `npm start` ya
# reestablece el reverse. (La IP LAN fallaba por WiFi inestable/aislamiento de cliente.)
EXPO_PUBLIC_BACKEND_URL=http://192.168.100.9:3000

# Solo afecta a dev (cuando se autodetecta el host). Default: 3000.
# EXPO_PUBLIC_DEV_BACKEND_PORT=3000

# Login con Google (client IDs OAuth de Google Cloud Console).
# WEB: imprescindible — el id_token se emite con este `aud` (lo verifica el backend).
# IOS: client ID nativo de iOS (su valor invertido va como iosUrlScheme en app.json).
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
